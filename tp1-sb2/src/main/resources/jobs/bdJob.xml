<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:p="http://www.springframework.org/schema/p"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:util="http://www.springframework.org/schema/util"
	xsi:schemaLocation="http://www.springframework.org/schema/batch http://www.springframework.org/schema/batch/spring-batch-2.1.xsd
		http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
		http://www.springframework.org/schema/util http://www.springframework.org/schema/util/spring-util.xsd">

	<job id="bdJob"
		xmlns="http://www.springframework.org/schema/batch">
		<step id="productStep"
			xmlns="http://www.springframework.org/schema/batch">
			<tasklet>
				<chunk reader="productReader"
					processor="compositeItemProcessor" writer="productWriter"
					commit-interval="10" />
			</tasklet>
		</step>
	</job>

	<bean id="productReader"
		class="org.springframework.batch.item.database.JdbcPagingItemReader"
		scope="step">
		<property name="dataSource" ref="domainDataSource" />
		<property name="rowMapper">
			<bean
				class="org.springframework.jdbc.core.BeanPropertyRowMapper">
				<constructor-arg
					value="org.formation.model.InputProduct" />
			</bean>
		</property>
		<property name="queryProvider">
			<bean
				class="org.springframework.batch.item.database.support.SqlPagingQueryProviderFactoryBean">
				<property name="dataSource" ref="domainDataSource" />
				<property name="sortKey" value="ID" />
				<!-- Intentionally put sort key second in the query list as a test -->
				<property name="selectClause"
					value="select id, hauteur,largeur,longueur,nom,reference" />
				<property name="fromClause" value="FROM produit" />
				<property name="whereClause"
					value="where fournisseur_id = :fournisseurId" />
			</bean>
		</property>
		<property name="pageSize" value="20" />
		<property name="parameterValues">
			<map>
				<entry key="fournisseurId" value="1" />
			</map>
		</property>
	</bean>


	<bean id="productWriter"
		class="org.springframework.batch.item.xml.StaxEventItemWriter">
		<property name="resource"
			value="file:/home/dthibau/Formations/SpringBatch/MyWork/products-out.xml" />
		<property name="marshaller" ref="outputProductMarshaller" />
		<property name="rootTagName" value="products-fournisseur1" />
		<property name="overwriteOutput" value="true" />
	</bean>
	<bean id="outputProductMarshaller"
		class="org.springframework.oxm.xstream.XStreamMarshaller">
		<property name="aliases">
			<util:map id="aliases">
				<entry key="produit" value="org.formation.model.OutputProduct" />
				<entry key="hauteur" value="java.lang.Float" />
				<entry key="largeur" value="java.lang.Float" />
				<entry key="ref" value="java.lang.String" />
			</util:map>
		</property>
	</bean>
	<bean id="flatFileWriter"
		class="org.springframework.batch.item.file.FlatFileItemWriter">
		<property name="resource"
			value="file:/home/dthibau/Formations/SpringBatch/MyWork/products-out.csv" />

		<property name="lineAggregator">
			<bean
				class="org.springframework.batch.item.file.transform.DelimitedLineAggregator">
				<property name="delimiter" value="," />
				<property name="fieldExtractor">
					<bean
						class="org.springframework.batch.item.file.transform.BeanWrapperFieldExtractor">
						<property name="names"
							value="reference,nom,hauteur,largeur,longueur" />
					</bean>
				</property>
			</bean>
		</property>
	</bean>

	<bean id="validator" class="org.formation.file.ProductValidator" />

	<bean id="compositeItemProcessor"
		class="org.springframework.batch.item.support.CompositeItemProcessor">
		<property name="delegates">
			<list>
				<bean
					class="org.springframework.batch.item.validator.ValidatingItemProcessor">
					<property name="validator" ref="validator" />
					<property name="filter" value="true" />
				</bean>
				<bean class="org.formation.file.ProductProcessor" />
			</list>
		</property>
	</bean>
</beans>