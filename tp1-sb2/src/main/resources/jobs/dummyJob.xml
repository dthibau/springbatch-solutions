<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:p="http://www.springframework.org/schema/p"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/batch http://www.springframework.org/schema/batch/spring-batch-2.1.xsd
		http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<job id="dummyJob"
		xmlns="http://www.springframework.org/schema/batch">
		<step id="first" next="secondStep"
			xmlns="http://www.springframework.org/schema/batch">
			<tasklet>
				<chunk reader="dummyReader" writer="dummyWriter"
					commit-interval="10" />
		
			</tasklet>
		</step>
		<step id="secondStep"
			xmlns="http://www.springframework.org/schema/batch">
			<tasklet>
				<chunk reader="dummyReader" writer="dummyWriter"
					commit-interval="10" />
			</tasklet>
		</step>
		<listeners>
			<listener ref="dummyJobListener"></listener>
		</listeners>
	</job>


	<bean id="dummyReader" class="org.formation.dummy.DummyReader">
	</bean>

	<bean id="dummyWriter" class="org.formation.dummy.DummyWriter">
	</bean>
	
	<bean id="dummyJobListener" class="org.formation.dummy.DummyJobListener">
	</bean>


</beans>